<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensa.project.controller.AjouterFacture">
    <children>
        <Label layoutX="14.0" layoutY="14.0" text="Ajouter une facture" />

        <Label layoutX="14.0" layoutY="50.0" text="Nom du Client:" />
        <TextField fx:id="txtNomClient" layoutX="120.0" layoutY="45.0" prefWidth="200.0" />

        <Label layoutX="14.0" layoutY="90.0" text="Montant HT:" />
        <TextField fx:id="txtMontantHT" layoutX="120.0" layoutY="85.0" prefWidth="200.0" />

        <Label layoutX="14.0" layoutY="130.0" text="Montant TTC:" />
        <TextField fx:id="txtMontantTTC" layoutX="120.0" layoutY="125.0" prefWidth="200.0" />

        <Label layoutX="14.0" layoutY="170.0" text="Date d'échéance:" />
        <TextField fx:id="txtDateEcheance" layoutX="120.0" layoutY="165.0" prefWidth="200.0" />

        <Button fx:id="btnSave" layoutX="120.0" layoutY="210.0" mnemonicParsing="false" text="Enregistrer" onAction="#saveFacture" />
        <Button fx:id="btnCancel" layoutX="230.0" layoutY="210.0" mnemonicParsing="false" text="Annuler" onAction="#cancelAction" />
    </children>
</AnchorPane>
